rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /works/{songId}/{uid}/current.webm {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (
          // create / update
          (
            request.resource != null
            && request.resource.size < 30 * 1024 * 1024
            && request.resource.contentType != null
            && (
              request.resource.contentType.matches('audio/.*')
              || request.resource.contentType == 'video/webm'
            )
          )
          // delete
          || (
            request.resource == null
            && resource != null
          )
        );
    }
  }
}
